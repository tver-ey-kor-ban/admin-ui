# Copy this file to .env.local and adjust values as needed.
# If VITE_API_URL is not set, the app connects to the production backend by default.

# Production backend (default — no need to set this unless you want to override)
VITE_API_URL=https://backend-1-s2fl.onrender.com/api/v1

# Local backend (uncomment when running the backend on your machine)
# VITE_API_URL=http://localhost:8000/api/v1
